{
  "root": true,
  "env": {
    "es2021": true,
    "node": true,
    "browser": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "semi": ["error", "always"],
    "indent": ["error", 2]
  },
  "overrides": [
    {
      "files": ["**/*.config.js", "playwright.config.js", "index.js"],
      "env": { "node": true },
      "rules": { "no-console": "off" }
    },
    {
      "files": ["renderer/**", "electron/**", "lib/**", "services/**", "workers/**"],
      "env": { "browser": true, "node": true }
    },
    {
      "files": ["**/*.test.js", "pipeline/**"],
      "env": { "jest": true }
    }
  ]
}
